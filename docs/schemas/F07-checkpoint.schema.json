{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "F07 agent checkpoint",
  "description": "Per-run snapshot written by didio-checkpoint-write.sh (scaffolded) and enriched by the agent itself when a soft warning arrives",
  "type": "object",
  "required": ["run_id", "updated_at"],
  "properties": {
    "run_id": {"type": "string"},
    "feature": {"type": "string"},
    "task": {"type": "string"},
    "role": {"type": "string"},
    "updated_at": {"type": "string"},
    "task_progress": {"type": "string"},
    "last_tool_result": {"type": "string"},
    "todo_state": {"type": "array"},
    "context_summary": {"type": "string"},
    "next_action_hint": {"type": "string"}
  },
  "additionalProperties": true
}
