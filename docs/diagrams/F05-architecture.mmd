        TPL["templates/<br/>(prompts, workflows,<br/>commands, diagrams,<br/>didio.config.json)"]
        SA["bin/didio-sync-all.sh"]
        SP["bin/didio-sync-project.sh"]
        TGT["target-projects.json"]
    end

